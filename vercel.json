{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "og-image.png", "use": "@vercel/static" },
    { "src": "hero.mp4", "use": "@vercel/static" },
    { "src": "afix-bathroom.png", "use": "@vercel/static" },
    { "src": "afix-kitchen.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/og-image.png", "dest": "/og-image.png" },
    { "src": "/hero.mp4", "dest": "/hero.mp4" },
    { "src": "/afix-bathroom.png", "dest": "/afix-bathroom.png" },
    { "src": "/afix-kitchen.png", "dest": "/afix-kitchen.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/hero.mp4",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
