{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing/index.html", "use": "@vercel/static" },
    { "src": "aircon-chemical-wash/index.html", "use": "@vercel/static" },
    { "src": "daikin-aircon-servicing/index.html", "use": "@vercel/static" },
    { "src": "mitsubishi-electric-aircon-servicing/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-tampines/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-jurong-west/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-woodlands/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-sengkang/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-punggol/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-hougang/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-yishun/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-bedok/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-ang-mo-kio/index.html", "use": "@vercel/static" },
    { "src": "aircon-servicing-choa-chu-kang/index.html", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "og-image.png", "use": "@vercel/static" },
    { "src": "hero.mp4", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/aircon-servicing", "dest": "/aircon-servicing/index.html" },
    { "src": "/aircon-servicing/", "dest": "/aircon-servicing/index.html" },
    { "src": "/aircon-chemical-wash", "dest": "/aircon-chemical-wash/index.html" },
    { "src": "/aircon-chemical-wash/", "dest": "/aircon-chemical-wash/index.html" },
    { "src": "/daikin-aircon-servicing", "dest": "/daikin-aircon-servicing/index.html" },
    { "src": "/daikin-aircon-servicing/", "dest": "/daikin-aircon-servicing/index.html" },
    { "src": "/mitsubishi-electric-aircon-servicing", "dest": "/mitsubishi-electric-aircon-servicing/index.html" },
    { "src": "/mitsubishi-electric-aircon-servicing/", "dest": "/mitsubishi-electric-aircon-servicing/index.html" },
    { "src": "/aircon-servicing-tampines", "dest": "/aircon-servicing-tampines/index.html" },
    { "src": "/aircon-servicing-tampines/", "dest": "/aircon-servicing-tampines/index.html" },
    { "src": "/aircon-servicing-jurong-west", "dest": "/aircon-servicing-jurong-west/index.html" },
    { "src": "/aircon-servicing-jurong-west/", "dest": "/aircon-servicing-jurong-west/index.html" },
    { "src": "/aircon-servicing-woodlands", "dest": "/aircon-servicing-woodlands/index.html" },
    { "src": "/aircon-servicing-woodlands/", "dest": "/aircon-servicing-woodlands/index.html" },
    { "src": "/aircon-servicing-sengkang", "dest": "/aircon-servicing-sengkang/index.html" },
    { "src": "/aircon-servicing-sengkang/", "dest": "/aircon-servicing-sengkang/index.html" },
    { "src": "/aircon-servicing-punggol", "dest": "/aircon-servicing-punggol/index.html" },
    { "src": "/aircon-servicing-punggol/", "dest": "/aircon-servicing-punggol/index.html" },
    { "src": "/aircon-servicing-hougang", "dest": "/aircon-servicing-hougang/index.html" },
    { "src": "/aircon-servicing-hougang/", "dest": "/aircon-servicing-hougang/index.html" },
    { "src": "/aircon-servicing-yishun", "dest": "/aircon-servicing-yishun/index.html" },
    { "src": "/aircon-servicing-yishun/", "dest": "/aircon-servicing-yishun/index.html" },
    { "src": "/aircon-servicing-bedok", "dest": "/aircon-servicing-bedok/index.html" },
    { "src": "/aircon-servicing-bedok/", "dest": "/aircon-servicing-bedok/index.html" },
    { "src": "/aircon-servicing-ang-mo-kio", "dest": "/aircon-servicing-ang-mo-kio/index.html" },
    { "src": "/aircon-servicing-ang-mo-kio/", "dest": "/aircon-servicing-ang-mo-kio/index.html" },
    { "src": "/aircon-servicing-choa-chu-kang", "dest": "/aircon-servicing-choa-chu-kang/index.html" },
    { "src": "/aircon-servicing-choa-chu-kang/", "dest": "/aircon-servicing-choa-chu-kang/index.html" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/og-image.png", "dest": "/og-image.png" },
    { "src": "/hero.mp4", "dest": "/hero.mp4" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/hero.mp4",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
